# ──────────────────────────────────────────────────────────────────────────
# Configurações Gerais
# ──────────────────────────────────────────────────────────────────────────
PORT=3000
DOMAIN=https://www.meditarfe.com
ADMIN_TOKEN=seu-token-admin-secreto

# ──────────────────────────────────────────────────────────────────────────
# SMTP - Configuração de Envio de Emails
# ──────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@meditarfe.com
SMTP_PASS=sua-senha-smtp
SMTP_FROM=noreply@meditarfe.com

# ──────────────────────────────────────────────────────────────────────────
# Groq API - Para Geração de Devocionais com IA
# ──────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=sua-chave-groq-aqui

# ──────────────────────────────────────────────────────────────────────────
# Hotmart - Integração de Pagamentos
# ──────────────────────────────────────────────────────────────────────────
HOTMART_WEBHOOK_SECRET=sua-chave-secreta-hotmart

# Exemplo de variáveis para diferentes ambientes:
# Desenvolvimento: DOMAIN=http://localhost:3000
# Produção: DOMAIN=https://www.meditarfe.com
# Sandbox Hotmart: Usar URLs de teste em hotmart.com
